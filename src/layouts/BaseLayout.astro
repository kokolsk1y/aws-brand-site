---
const { title = 'AWS Products — Электрика нового стандарта', description = 'Российский бренд электрики с вниманием к деталям', ogImage } = Astro.props;
import '../styles/main.css';
import { ClientRouter } from 'astro:transitions';

const SITE = 'https://kokolsk1y.github.io';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = SITE + BASE + Astro.url.pathname;
const finalOgImage = ogImage ? (ogImage.startsWith('http') ? ogImage : SITE + BASE + ogImage) : SITE + BASE + '/logo/AWS.png';
---
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#0a0908" />
    <link rel="icon" type="image/png" href={`${BASE}/logo/AWS.png`} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet" />
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <ClientRouter />
</head>
<body>
    <!-- NAVIGATION PROGRESS BAR -->
    <div class="nav-progress" id="navProgress" aria-hidden="true"><div class="nav-progress__fill"></div></div>

    <!-- SCROLL PROGRESS BAR -->
    <div class="scroll-progress" id="scrollProgress"><div class="scroll-progress__bar"></div></div>

    <!-- LOADING SPLASH — показывается только при первом заходе -->
    <div class="splash" id="splash" aria-hidden="true">
        <div class="splash__logo-wrap">
            <img src={`${BASE}/logo/AWS.png`} alt="AWS Products" class="splash__logo" />
            <div class="splash__line"></div>
        </div>
    </div>
    <header class="header dark scrolled" id="header">
        <div class="header__inner">
            <div class="header__left">
                <button class="header__burger" id="menuToggle" aria-label="Меню" aria-expanded="false" aria-controls="sideMenu">
                    <span></span><span></span><span></span>
                </button>
                <span class="header__slogan desktop-only">Качество в каждой детали</span>
            </div>
            <div class="header__center">
                <a href="/aws-brand-site/" class="header__logo" data-astro-reload>
                    <img src={`${BASE}/logo/AWS.png`} alt="AWS Products" class="header__logo-img" />
                </a>
            </div>
            <div class="header__right">
                <a href="/aws-brand-site/#about" class="header__link desktop-only" data-astro-reload>О бренде</a>
                <a href="/aws-brand-site/#buy" class="header__link desktop-only" data-astro-reload>Где купить</a>
                <a href="/aws-brand-site/#contacts" class="header__link desktop-only" data-astro-reload>Контакты</a>
            </div>
        </div>
    </header>

    <div class="side-menu" id="sideMenu">
        <div class="side-menu__overlay" id="menuOverlay"></div>
        <div class="side-menu__panel">
            <button class="side-menu__close" id="menuClose">&times;</button>
            <nav class="side-menu__nav">
                <div class="side-menu__group">
                    <button class="side-menu__toggle">Ассортимент <span class="side-menu__arrow">&#9662;</span></button>
                    <div class="side-menu__dropdown">
                        <a href="/aws-brand-site/series/uno" class="side-menu__sub" data-preview="/aws-brand-site/img/series/uno-1kl-w.webp" data-preview-title="УНО">Серия УНО</a>
                        <a href="/aws-brand-site/series/aura" class="side-menu__sub" data-preview="/aws-brand-site/img/series/aura-1kl-w.webp" data-preview-title="АУРА">Серия АУРА</a>
                        <a href="/aws-brand-site/series/design" class="side-menu__sub" data-preview-title="ДИЗАЙН · скоро">Серия ДИЗАЙН</a>
                        <a href="/aws-brand-site/category/extensions-home" class="side-menu__sub" data-preview="/aws-brand-site/img/products/AWS-H03-1,5.webp" data-preview-title="Удлинители бытовые">Удлинители бытовые</a>
                        <a href="/aws-brand-site/category/extensions-garden" class="side-menu__sub" data-preview="/aws-brand-site/img/products/AWS-HZ2-01-15.webp" data-preview-title="Удлинители садовые">Удлинители садовые</a>
                        <a href="/aws-brand-site/category/power-connectors" class="side-menu__sub" data-preview="/aws-brand-site/img/products/SN-33.webp" data-preview-title="Силовые разъёмы">Силовые разъёмы</a>
                        <a href="/aws-brand-site/category/clamps" class="side-menu__sub" data-preview="/aws-brand-site/img/products/SN-222415.webp" data-preview-title="Клеммы">Клеммы</a>
                        <a href="/aws-brand-site/category/patch-cords" class="side-menu__sub" data-preview="/aws-brand-site/img/products/AWS-13010.webp" data-preview-title="Патч-корды">Патч-корды</a>
                        <a href="/aws-brand-site/category/cables" class="side-menu__sub" data-preview="/aws-brand-site/img/products/AWS-12982.webp" data-preview-title="Кабель">Кабель</a>
                    </div>
                </div>
                <a href="/aws-brand-site/#about" class="side-menu__item" data-astro-reload>О бренде</a>
                <a href="/aws-brand-site/#buy" class="side-menu__item" data-astro-reload>Где купить</a>
                <a href="/aws-brand-site/#contacts" class="side-menu__item" data-astro-reload>Контакты</a>
            </nav>
            <div class="side-menu__contacts">
                <a href="mailto:info@awsproducts.ru">info@awsproducts.ru</a>
            </div>
        </div>

        <!-- Preview panel (desktop only) -->
        <div class="side-menu__preview" id="sideMenuPreview" aria-hidden="true">
            <div class="side-menu__preview-img-wrap">
                <img src="" alt="" class="side-menu__preview-img" id="sideMenuPreviewImg" />
                <div class="side-menu__preview-placeholder" id="sideMenuPreviewPlaceholder">Скоро</div>
            </div>
            <div class="side-menu__preview-title" id="sideMenuPreviewTitle"></div>
        </div>
    </div>

    <main>
        <slot />
    </main>

    <footer class="footer-v2" id="contacts">
        <div class="footer-v2__inner">

            <!-- Колонки -->
            <div class="footer-v2__cols">
                <div class="footer-v2__col">
                    <span class="footer-v2__col-title">Коллекции</span>
                    <a href="/aws-brand-site/series/uno">УНО</a>
                    <a href="/aws-brand-site/series/aura">АУРА</a>
                    <a href="/aws-brand-site/series/design">ДИЗАЙН <span class="footer-v2__soon-badge">скоро</span></a>
                </div>
                <div class="footer-v2__col">
                    <span class="footer-v2__col-title">Ассортимент</span>
                    <a href="/aws-brand-site/category/extensions-home">Удлинители бытовые</a>
                    <a href="/aws-brand-site/category/extensions-garden">Удлинители садовые</a>
                    <a href="/aws-brand-site/category/power-connectors">Силовые разъёмы</a>
                    <a href="/aws-brand-site/category/clamps">Клеммы</a>
                    <a href="/aws-brand-site/category/patch-cords">Патч-корды</a>
                    <a href="/aws-brand-site/category/cables">Кабель</a>
                </div>
                <div class="footer-v2__col">
                    <span class="footer-v2__col-title">Компания</span>
                    <a href="/aws-brand-site/#about" data-astro-reload>О бренде</a>
                    <a href="/aws-brand-site/#advantages" data-astro-reload>Преимущества</a>
                    <a href="/aws-brand-site/#buy" data-astro-reload>Где купить</a>
                </div>
                <div class="footer-v2__col">
                    <span class="footer-v2__col-title">Связь</span>
                    <a href="mailto:info@awsproducts.ru">info@awsproducts.ru</a>
                </div>
            </div>

            <!-- Bottom strip -->
            <div class="footer-v2__bottom">
                <div class="footer-v2__brand">
                    <img src={`${BASE}/logo/AWS.png`} alt="" class="footer-v2__logo" />
                    <span>Awesome Products</span>
                </div>
                <div class="footer-v2__legal">
                    <span>&copy; 2026 AWS Products</span>
                    <span class="footer-v2__sep">·</span>
                    <span class="footer-v2__legal-soon" title="Появится скоро">Политика конфиденциальности</span>
                    <span class="footer-v2__sep">·</span>
                    <span class="footer-v2__legal-soon" title="Появится скоро">Оферта</span>
                </div>
                <div class="footer-v2__loc">Россия</div>
            </div>

        </div>
    </footer>

    <script is:inline>
      // ============================
      // SPA-safe init: всё в initPage(), вызов на load и на каждый astro:page-load
      // ============================

      // Глобальное (один раз):
      // 1. Splash screen — ТОЛЬКО на первом холодном заходе
      (function () {
        const splash = document.getElementById('splash');
        if (!splash) return;
        const seen = sessionStorage.getItem('aws-splash-seen');
        if (seen) { splash.remove(); return; }
        sessionStorage.setItem('aws-splash-seen', '1');
        let hidden = false;
        const hide = () => {
          if (hidden) return;
          hidden = true;
          splash.classList.add('is-hiding');
          setTimeout(() => splash.remove(), 400);
        };
        if (document.readyState !== 'loading') setTimeout(hide, 600);
        else document.addEventListener('DOMContentLoaded', () => setTimeout(hide, 600));
        setTimeout(hide, 2000);
      })();

      // 2. Удалить splash из нового документа до SPA-swap (чтобы не мигал)
      document.addEventListener('astro:before-swap', e => {
        const s = e.newDocument.getElementById('splash');
        if (s) s.remove();
      });

      // 3. Navigation progress bar — показывает загрузку при SPA-переходах
      (function () {
        const navBar = document.getElementById('navProgress');
        if (navBar) {
          document.addEventListener('astro:before-preparation', () => {
            navBar.classList.add('is-active', 'is-animating');
            navBar.classList.remove('is-done');
          });
          document.addEventListener('astro:page-load', () => {
            navBar.classList.remove('is-animating');
            navBar.classList.add('is-done');
            setTimeout(() => navBar.classList.remove('is-active', 'is-done'), 500);
          });
        }
      })();

      // 4. Scroll progress bar — слушатель один раз, переживает SPA-навигацию
      (function () {
        const update = () => {
          const bar = document.querySelector('.scroll-progress__bar');
          if (!bar) return;
          const h = document.documentElement.scrollHeight - window.innerHeight;
          const p = h > 0 ? (window.scrollY / h) * 100 : 0;
          bar.style.transform = 'scaleX(' + (p / 100) + ')';
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
        document.addEventListener('astro:page-load', update);
      })();

      // ============================
      // Per-page init (вызывается на каждой странице)
      // ============================

      // ⚠️ Watchdog: защита от зависших состояний UI
      // Лечит баг «после многих кликов сайт перестаёт реагировать».
      if (!window._overflowWatchdog) {
        window._overflowWatchdog = setInterval(() => {
          const modalOpen = document.querySelector(
            '.side-menu.open, .buy-modal:not([hidden]), .doc-modal:not([hidden]), .prod-modal:not([hidden])'
          );
          // 1) overflow:hidden без открытой модалки — разблокировать
          if (document.body.style.overflow === 'hidden' && !modalOpen) {
            document.body.style.overflow = '';
          }
          // 2) pointer-events: none случайно навешенный на body/html — снять
          if (document.body.style.pointerEvents === 'none') {
            document.body.style.pointerEvents = '';
          }
          if (document.documentElement.style.pointerEvents === 'none') {
            document.documentElement.style.pointerEvents = '';
          }
          // 3) Зависшие .is-filter-out на карточках (если фильтр давно не кликали)
          const stuck = document.querySelectorAll('.prod-card.is-filter-out');
          if (stuck.length && !window._lastFilterClick) {
            stuck.forEach(c => c.classList.remove('is-filter-out'));
          } else if (stuck.length && Date.now() - (window._lastFilterClick || 0) > 1500) {
            stuck.forEach(c => c.classList.remove('is-filter-out'));
          }
          // 4) Зависшие .is-swapping (если onload/onerror не выстрелили)
          document.querySelectorAll('.prod-card__photo--main.is-swapping, .ser-lineup__img.is-swapping').forEach(im => {
            const ts = Number(im.dataset.swapStart || 0);
            if (!ts) { im.dataset.swapStart = String(Date.now()); return; }
            if (Date.now() - ts > 2000) {
              im.classList.remove('is-swapping');
              im.removeAttribute('data-swap-start');
            }
          });
        }, 600);
        // ESC — мгновенно снимает любые блокировки + закрывает меню
        document.addEventListener('keydown', e => {
          if (e.key !== 'Escape') return;
          document.body.style.overflow = '';
          document.body.style.pointerEvents = '';
          document.documentElement.style.pointerEvents = '';
          document.querySelectorAll('.side-menu.open').forEach(el => el.classList.remove('open'));
          document.querySelectorAll('.buy-modal:not([hidden]), .doc-modal:not([hidden])').forEach(el => el.hidden = true);
          document.querySelectorAll('.prod-card.is-filter-out').forEach(c => c.classList.remove('is-filter-out'));
        });
      }

      function initPage() {
        // ---- Бургер-меню ----
        const sm = document.getElementById('sideMenu');
        const mt = document.getElementById('menuToggle');
        const mc = document.getElementById('menuClose');
        const mo = document.getElementById('menuOverlay');
        const openMenu  = () => { if (sm) { sm.classList.add('open'); document.body.style.overflow = 'hidden'; if (mt) mt.setAttribute('aria-expanded', 'true'); } };
        const closeMenu = () => { if (sm) { sm.classList.remove('open'); document.body.style.overflow = ''; if (mt) mt.setAttribute('aria-expanded', 'false'); } };
        if (mt && !mt._inited) { mt._inited = true; mt.addEventListener('click', openMenu); }
        if (mc && !mc._inited) { mc._inited = true; mc.addEventListener('click', closeMenu); }
        if (mo && !mo._inited) { mo._inited = true; mo.addEventListener('click', closeMenu); }
        document.querySelectorAll('.side-menu__toggle').forEach(b => {
          if (b._inited) return; b._inited = true;
          b.addEventListener('click', () => b.parentElement.classList.toggle('open'));
        });
        document.querySelectorAll('.side-menu__item, .side-menu__sub').forEach(a => {
          if (a._closeInited) return; a._closeInited = true;
          a.addEventListener('click', closeMenu);
        });

        // ---- Menu preview on hover (desktop) ----
        const previewBox = document.getElementById('sideMenuPreview');
        const previewImg = document.getElementById('sideMenuPreviewImg');
        const previewPh = document.getElementById('sideMenuPreviewPlaceholder');
        const previewTitle = document.getElementById('sideMenuPreviewTitle');
        if (previewBox) {
          document.querySelectorAll('.side-menu__sub[data-preview-title]').forEach(link => {
            if (link._previewInited) return; link._previewInited = true;
            link.addEventListener('mouseenter', () => {
              const img = link.dataset.preview;
              const ttl = link.dataset.previewTitle;
              if (previewTitle) previewTitle.textContent = ttl || '';
              if (img && previewImg) {
                previewImg.src = img;
                previewImg.style.display = '';
                if (previewPh) previewPh.style.display = 'none';
              } else if (previewImg) {
                previewImg.style.display = 'none';
                if (previewPh) previewPh.style.display = '';
              }
              previewBox.classList.add('is-visible');
            });
          });
          const dropdown = document.querySelector('.side-menu__dropdown');
          if (dropdown && !dropdown._previewInited) {
            dropdown._previewInited = true;
            dropdown.addEventListener('mouseleave', () => previewBox.classList.remove('is-visible'));
          }
        }

        // ---- 3D tilt — только на устройствах с указателем (не на touch) ----
        if (!window.matchMedia('(hover: none)').matches) {
          document.querySelectorAll('[data-tilt]').forEach(el => {
            if (el._tiltInited) return;
            el._tiltInited = true;
            const maxRot = parseFloat(el.dataset.tiltMax) || 8;
            let rafId = null;
            el.addEventListener('mousemove', e => {
              if (rafId) return;
              rafId = requestAnimationFrame(() => {
                const rect = el.getBoundingClientRect();
                const x = (e.clientX - rect.left) / rect.width - 0.5;
                const y = (e.clientY - rect.top) / rect.height - 0.5;
                el.style.transform = 'perspective(1000px) rotateX(' + (-y * maxRot) + 'deg) rotateY(' + (x * maxRot) + 'deg) translateY(-4px)';
                rafId = null;
              });
            }, { passive: true });
            el.addEventListener('mouseleave', () => { el.style.transform = ''; });
          });
        }

        // ---- Reveal on scroll ----
        // Авто-добавление data-reveal-section на средне-размерные <section>.
        // ИСКЛЮЧЕНИЯ: длинные секции с каталогом (.ser-lineup, .cat-products, .prod-related)
        // — у них высота > viewport, observer не успевает триггернуть.
        const skipRevealClasses = ['ser-lineup', 'cat-products', 'prod-related', 'cat-grid', 'ser-related', 'ser-features'];
        document.querySelectorAll('main > section, main > div > section').forEach(el => {
          if (skipRevealClasses.some(c => el.classList.contains(c))) return;
          if (!el.hasAttribute('data-reveal-item') && !el.hasAttribute('data-reveal-section')) {
            el.setAttribute('data-reveal-section', '');
          }
        });

        // Старая is-visible-система — для секций без data-reveal (заголовки, баннеры)
        if ('IntersectionObserver' in window) {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              entry.target.classList.toggle('is-visible', entry.isIntersecting);
            });
          }, { threshold: 0, rootMargin: '0px 0px -5% 0px' });
          document.querySelectorAll('[data-reveal-item], [data-reveal-section]').forEach(el => obs.observe(el));
        } else {
          document.querySelectorAll('[data-reveal-item], [data-reveal-section]').forEach(el => el.classList.add('is-visible'));
        }

        // ---- GSAP scrub-engine для [data-reveal] ----
        // Ждём пока gsap+ScrollTrigger загрузятся (CDN async), потом инициализируем.
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          const tryInit = (attempt = 0) => {
            if (!window.gsap || !window.ScrollTrigger) {
              if (attempt < 30) return setTimeout(() => tryInit(attempt + 1), 50);
              return;
            }
            gsap.registerPlugin(ScrollTrigger);

            // Чистим ВСЕ старые триггеры при SPA-навигации, чтобы не копились в памяти
            ScrollTrigger.getAll().forEach(t => t.kill());

            document.querySelectorAll('[data-reveal]').forEach((el, idx) => {
              const i = parseFloat(el.style.getPropertyValue('--i')) || 0;
              const startOffset = Math.min(i * 1.5, 12);
              ScrollTrigger.create({
                id: 'reveal-' + idx + '-' + Date.now(),
                trigger: el,
                start: `top ${95 - startOffset}%`,
                end: `top ${70 - startOffset * 0.5}%`,
                scrub: 0.5,
                invalidateOnRefresh: true,
                onUpdate: self => el.style.setProperty('--reveal-progress', self.progress.toFixed(3))
              });
            });

            // Параллакс крупной картинки категории/серии
            document.querySelectorAll('.cat-hero__media-img, .ser-hero__media img').forEach((img, pi) => {
              gsap.to(img, {
                yPercent: 6,
                ease: 'none',
                scrollTrigger: {
                  id: 'parallax-' + pi + '-' + Date.now(),
                  trigger: img.closest('.cat-hero, .ser-hero') || img,
                  start: 'top top',
                  end: 'bottom top',
                  scrub: 0.6,
                  invalidateOnRefresh: true
                }
              });
            });

            // Пересчёт позиций после load (картинки лениво грузятся)
            ScrollTrigger.refresh();
            window.addEventListener('load', () => ScrollTrigger.refresh(), { once: true });
          };
          tryInit();
        }

        // ---- Hash scroll (после View Transitions) ----
        if (window.location.hash && window.location.hash.length > 1) {
          const target = document.querySelector(window.location.hash);
          if (target) {
            const jump = () => {
              const rect = target.getBoundingClientRect();
              const y = rect.top + window.pageYOffset - 80;
              window.scrollTo({ top: y, behavior: 'smooth' });
            };
            jump();
            setTimeout(jump, 250);
            setTimeout(jump, 700);
          }
        }
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>
</body>
</html>
