---
import BaseLayout from '../layouts/BaseLayout.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Страница не найдена — AWS Products" description="Такой страницы нет. Вернитесь на главную или в каталог.">
  <section class="nf">
    <div class="nf__inner">
      <span class="nf__code">404</span>
      <h1 class="nf__title">Страница не найдена</h1>
      <p class="nf__text">Возможно, адрес устарел или страница была перемещена.<br>Вернитесь на главную или посмотрите ассортимент.</p>
      <div class="nf__actions">
        <a href={`${BASE}/`} class="btn-switch" data-astro-reload>На главную</a>
        <a href={`${BASE}/#categories`} class="nf__link-sub" data-astro-reload>Посмотреть ассортимент →</a>
      </div>
    </div>
  </section>

  <style is:global>
    .nf {
      min-height: calc(100vh - 80px);
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(180deg, var(--warm-100, #f7f4ef) 0%, var(--white, #fff) 100%);
      padding: 120px 24px 80px;
    }
    .nf__inner { max-width: 560px; text-align: center; }
    .nf__code {
      display: block;
      font-size: clamp(96px, 18vw, 200px);
      font-weight: 900; line-height: 0.9; letter-spacing: -6px;
      color: transparent;
      -webkit-text-stroke: 2px rgba(0,0,0,0.12);
      margin-bottom: 20px;
    }
    .nf__title {
      font-size: clamp(32px, 4vw, 56px);
      font-weight: 800; line-height: 1.05; letter-spacing: -1px;
      margin-bottom: 16px; color: var(--black, #111);
    }
    .nf__text {
      font-size: 16px; line-height: 1.6;
      color: var(--gray-600, #666);
      margin-bottom: 40px;
    }
    .nf__actions {
      display: flex; flex-direction: column; align-items: center; gap: 20px;
    }
    .nf__link-sub {
      font-size: 13px; font-weight: 500; letter-spacing: 1.2px; text-transform: uppercase;
      color: var(--gray-600, #666); text-decoration: none;
      border-bottom: 1px solid var(--gray-200, #ddd);
      padding-bottom: 2px;
      transition: color 0.2s ease, border-color 0.2s ease;
    }
    .nf__link-sub:hover {
      color: var(--black, #111);
      border-color: var(--black, #111);
    }
  </style>
</BaseLayout>
