---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categoriesMeta from '../../data/categories.json';
import productsAll from '../../../public/products.json';
import { getProductPhotos } from '../../utils/photos.js';

export async function getStaticPaths() {
  return Object.keys(categoriesMeta).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const category = categoriesMeta[slug];

// Маппинг slug → ключ в products.json
const slugToKey = {
  'extensions-home': 'udl_home',
  'extensions-garden': 'udl_garden',
  'power-connectors': 'power',
  'clamps': 'clamps',
  'patch-cords': 'patch',
  'cables': 'cable'
};

const productData = productsAll[slugToKey[slug]] || { items: [] };
const products = productData.items || [];

// Группировка по подтипам (если задана в category.groups)
function buildGroups(items, groupDefs) {
  if (!groupDefs || !groupDefs.length) return null;
  const used = new Set();
  const groups = groupDefs.map(g => {
    const fn = new Function('i', 'return ' + g.test);
    const matched = items.filter(it => {
      try { return fn(it); } catch (e) { return false; }
    });
    matched.forEach(it => used.add(it.article));
    return { key: g.key, title: g.title, items: matched };
  }).filter(g => g.items.length > 0);
  // Остальные товары — в группу "Прочее"
  const rest = items.filter(it => !used.has(it.article));
  if (rest.length) groups.push({ key: 'other', title: 'Прочее', items: rest });
  return groups;
}
const productGroups = buildGroups(products, category.groups);

// Cross-sell: все остальные категории (до 5 на странице)
const otherCats = Object.values(categoriesMeta)
  .filter(c => c.slug !== slug);

// Парсинг характеристик — универсально для всех категорий
function extractMeta(name) {
  const meta = [];
  // Длина в метрах (удлинители, патчи, кабели)
  const len = name.match(/(\d+(?:[,.]\d+)?)\s*м(?![м²])/);
  if (len) meta.push(`${len[1].replace(',', '.')} м`);
  // Гнёзда (удлинители)
  const sockets = name.match(/(\d+)\s*гн/);
  if (sockets) meta.push(`${sockets[1]} гнёзд`);
  // Заземление
  if (/с\/з/.test(name)) meta.push('с заземлением');
  else if (/б\/з/.test(name)) meta.push('без заземл.');
  // IP-класс (разъёмы, коннекторы)
  const ip = name.match(/IP\s*(\d{2})/i);
  if (ip) meta.push(`IP${ip[1]}`);
  // Сила тока (клеммы, разъёмы)
  const amp = name.match(/(\d+)\s*А(?![a-z])/);
  if (amp) meta.push(`${amp[1]} А`);
  // Отверстия (клеммы)
  const holes = name.match(/(\d+)\s*отверст/i);
  if (holes) meta.push(`${holes[1]} отв.`);
  // Рычажковая клемма
  if (/рычажк/i.test(name)) meta.push('рычажк.');
  // Категория кабеля (Cat.5e, Cat.6)
  const cat = name.match(/CAT\.?\s*(\d[a-zA-Z]*)/i);
  if (cat) meta.push(`Cat.${cat[1]}`);
  // Тип экранирования кабеля
  if (/FTP/i.test(name) && !meta.some(m => /FTP/i.test(m))) meta.push('FTP');
  if (/\bUTP\b/i.test(name) && !meta.some(m => /UTP/i.test(m))) meta.push('UTP');
  if (/SAT-\d+/i.test(name)) meta.push('SAT');
  // Применение
  if (/OUTDOOR/i.test(name)) meta.push('Outdoor');
  else if (/INDOOR/i.test(name)) meta.push('Indoor');
  // Сечение провода (клеммы)
  const wire = name.match(/(\d+(?:[,.]\d+)?)-(\d+(?:[,.]\d+)?)\s*мм²?/);
  if (wire) meta.push(`${wire[1].replace(',','.')}–${wire[2].replace(',','.')} мм²`);
  return meta.slice(0, 3); // максимум 3 чипа
}

function shortName(name) {
  // Кабели — убираем технический мусор, оставляем суть в ≤2 строки
  // АКСИОМА: результат должен умещаться в 2 строки карточки (~60 символов)
  if (/^Кабель/i.test(name)) {
    return name
      .replace(/\s+AWS(?=\s)/g, '')           // "AWS SAT-703" → убрать "AWS"
      .replace(/\s*\bDIGITAL\b/gi, '')        // SAT-703 всегда цифровой — избыточно
      .replace(/\s*\(Цифровой\)/gi, '')       // русский дубликат DIGITAL
      .replace(/\s+1мм,?/g, '')               // диаметр жилы — не нужен потребителю
      .replace(/\s*\b0\d{2}\b/g, '')          // коды моделей: 046, 051, 056, 058
      .replace(/\s*\bCU\b/g, '')              // CU избыточно — "(медь)" ниже
      .replace(/\bINDOOR\b/gi, 'внутренний')
      .replace(/\bOUTDOOR\b/gi, 'наружный')
      .replace(/\bpremium\b/gi, 'Премиум')
      .replace(/\bCAT\.?\s*5E\b/gi, 'Cat.5e')
      .replace(/\bCAT\.?\s*6\b/gi, 'Cat.6')
      .replace(/\s{2,}/g, ' ')
      .trim();
  }

  // Клеммы — убираем артикул SN/AWS в имени и упаковочную информацию
  if (/^Клемма|^Коннектор/i.test(name)) {
    return name
      .replace(/\s+(?:SN|AWS)-\S+/g, '')
      .replace(/\s*\(\d+шт\)/g, '')
      .replace(/\s*\(штуками\)/g, '')
      .replace(/\s*,\s*уп\.?/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  return name
    .replace(/\s*\(AWSPRODUCTS\)/gi, '')
    .replace(/AWS-\S+/g, '')
    .replace(/AWSproducts?/gi, '')
    .replace(/\s+/g, ' ')
    .trim();
}
---
<BaseLayout title={`${category.title} — AWS Products`} description={category.description}>

  <!-- HERO КАТЕГОРИИ -->
  <section class="cat-hero">
    <div class="cat-hero__inner">
      <nav class="cat-hero__crumbs">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/#categories">Ассортимент</a>
        <span>/</span>
        <span class="cat-hero__crumbs-current">{category.title}</span>
      </nav>

      <div class="cat-hero__grid">
        <div class="cat-hero__text">
          <h1 class="cat-hero__title" data-reveal="focus">{category.title}</h1>
          <p class="cat-hero__subtitle" data-reveal="blur">{category.subtitle}</p>
          <p class="cat-hero__desc" data-reveal="blur">{category.description}</p>
        </div>
        <div class="cat-hero__media" data-reveal="zoom">
          <img src={category.cover} alt={category.title} class="cat-hero__media-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ФИЛЬТРЫ + GRID -->
  <section class="cat-products">
    <div class="cat-products__inner">
      {category.filters && (
        <div class="cat-filters" id="catFilters">
          <div class="cat-filters__scroll">
            {category.filters.map(f => (
              <button class={`cat-filters__chip ${f.key === 'all' ? 'active' : ''}`} data-filter={f.key} data-test={f.test}>{f.label}</button>
            ))}
          </div>
        </div>
      )}

      {productGroups && (
        <div class="cat-controls-bar">
          <button class="cat-toggle-all" id="catToggleAll" type="button">
            <span class="cat-toggle-all__text">Свернуть все</span>
            <svg viewBox="0 0 12 12" class="cat-toggle-all__icon" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      )}

      {productGroups ? (
        <div id="catGrid" class="cat-groups">
          {productGroups.map(group => (
            <section class="cat-group" data-group={group.key}>
              <button class="cat-group__head" type="button" aria-expanded="true">
                <h3 class="cat-group__title">{group.title}</h3>
                <span class="cat-group__count">{group.items.length}</span>
                <svg viewBox="0 0 14 14" class="cat-group__chevron" aria-hidden="true">
                  <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="cat-group__content" data-open="true">
                <div class="cat-group__inner">
                <div class="cat-grid" data-reveal-grid>
                  {group.items.map((p, idx) => {
                    const meta = extractMeta(p.name);
                    const hasOverride = p.photo && p.photo !== `img/products/${p.article}.webp`;
                    const photos = hasOverride ? [] : getProductPhotos(p.article);
                    const main = hasOverride ? p.photo.replace(/^img\//, '/img/') : (photos[0] || p.photo?.replace(/^img\//, '/img/'));
                    const showDots = photos.length >= 2;
                    return (
                      <a href={`/product/${p.article}`} class="prod-card" data-name={p.name} data-tilt data-tilt-max="6" data-reveal="slide" style={`--i: ${idx % 9}`}>
                        <div class="prod-card__img">
                          <img src={main} alt={p.name} class="prod-card__photo prod-card__photo--main" loading="lazy" />
                        </div>
                        <div class="prod-card__info">
                          <span class="prod-card__article">{p.article}</span>
                          <h3 class="prod-card__name">{shortName(p.name)}</h3>
                          {(meta.length > 0 || showDots) && (
                            <div class="prod-card__meta-row">
                              {meta.length > 0 && (
                                <div class="prod-card__meta">
                                  {meta.map(m => <span class="prod-card__chip">{m}</span>)}
                                </div>
                              )}
                              {showDots && (
                                <div class="prod-card__dots" aria-label="Переключить фото">
                                  {photos.map((src, i) => (
                                    <span class={`prod-card__dot${i === 0 ? ' is-active' : ''}`} role="button" tabindex="0" data-photo-idx={i} data-photo-src={src} aria-label={`Фото ${i + 1}`}></span>
                                  ))}
                                </div>
                              )}
                            </div>
                          )}
                        </div>
                      </a>
                    );
                  })}
                </div>
                </div>
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="cat-grid" id="catGrid" data-reveal-grid>
          {products.map((p, idx) => {
            const meta = extractMeta(p.name);
            const hasOverride = p.photo && p.photo !== `img/products/${p.article}.webp`;
            const photos = hasOverride ? [] : getProductPhotos(p.article);
            const main = hasOverride ? p.photo.replace(/^img\//, '/img/') : (photos[0] || p.photo?.replace(/^img\//, '/img/'));
            const showDots = photos.length >= 2;
            return (
              <a href={`/product/${p.article}`} class="prod-card" data-name={p.name} data-tilt data-tilt-max="6" data-reveal="slide" style={`--i: ${idx % 9}`}>
                <div class="prod-card__img">
                  <img src={main} alt={p.name} class="prod-card__photo prod-card__photo--main" loading="lazy" />
                </div>
                <div class="prod-card__info">
                  <span class="prod-card__article">{p.article}</span>
                  <h3 class="prod-card__name">{shortName(p.name)}</h3>
                  {(meta.length > 0 || showDots) && (
                    <div class="prod-card__meta-row">
                      {meta.length > 0 && (
                        <div class="prod-card__meta">
                          {meta.map(m => <span class="prod-card__chip">{m}</span>)}
                        </div>
                      )}
                      {showDots && (
                        <div class="prod-card__dots" aria-label="Переключить фото">
                          {photos.map((src, i) => (
                            <span class={`prod-card__dot${i === 0 ? ' is-active' : ''}`} role="button" tabindex="0" data-photo-idx={i} data-photo-src={src} aria-label={`Фото ${i + 1}`}></span>
                          ))}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}

      {products.length === 0 && (
        <div class="cat-empty">Каталог в подготовке. Скоро здесь появятся товары.</div>
      )}
    </div>
  </section>

  <!-- CROSS-SELL -->
  <section class="cat-related">
    <div class="cat-related__inner">
      <h2 class="cat-related__title" data-reveal="focus">Возможно вас<br>заинтересует</h2>
      <div class="cat-related__grid" data-reveal-grid>
        {otherCats.map((c, idx) => (
          <a href={`/category/${c.slug}`} class="cat-related__card" data-astro-reload data-tilt data-tilt-max="5" data-reveal="slide" style={`--i: ${idx}`}>
            <div class="cat-related__img">
              <img src={c.cover} alt={c.title} loading="lazy" />
            </div>
            <h3 class="cat-related__name">{c.title}</h3>
            <span class="cat-related__sub">{c.subtitle}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cat-cta">
    <div class="cat-cta__inner">
      <h2 class="cat-cta__title" data-reveal="focus">Не нашли подходящий?</h2>
      <p class="cat-cta__sub" data-reveal="blur">Напишите нам — подберём вариант под вашу задачу</p>
      <a href="mailto:info@awsproducts.ru" class="btn-switch" data-reveal="slide">Связаться</a>
    </div>
  </section>

  <!-- МОДАЛКА «Где купить» -->
  <div class="buy-modal" id="buyModal" role="dialog" aria-modal="true" aria-labelledby="buyModalTitle" hidden>
    <div class="buy-modal__overlay" id="buyModalOverlay"></div>
    <div class="buy-modal__panel">
      <button class="buy-modal__close" id="buyModalClose" aria-label="Закрыть">&times;</button>
      <p class="label">Где купить</p>
      <h3 class="buy-modal__title" id="buyModalTitle">Товар</h3>
      <p class="buy-modal__article" id="buyModalArticle"></p>
      <div class="buy-modal__links">
        <a href="https://www.ozon.ru/seller/ip-popov-a-yu/" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">OZON</span>
          <span class="buy-modal__link-text">Маркетплейс Ozon</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
        <a href="https://www.wildberries.ru/brands/312201750-awsproducts" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">WB</span>
          <span class="buy-modal__link-text">Wildberries</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
        <a href="https://stv39.ru/help/nashi-partnery/awsproducts/" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">ЭЦ</span>
          <span class="buy-modal__link-text">Электроцентр</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Точки переключения фото на карточках товаров.
    // Лёгкая схема: 1 listener на всю сетку, фото грузятся только при первом клике
    // (браузер кэширует — повторные мгновенные).
    (function () {
      const grid = document.getElementById('catGrid');
      if (!grid || grid.dataset.dotsInit === '1') return;
      grid.dataset.dotsInit = '1';
      // Пред-грузка: после загрузки страницы тихо подгружаем 2-е фото для всех карточек
      function preloadSecondaries() {
        grid.querySelectorAll('.prod-card__dot[data-photo-idx="1"]').forEach(d => {
          const src = d.dataset.photoSrc;
          if (src) { const im = new Image(); im.decoding = 'async'; im.src = src; }
        });
      }
      if ('requestIdleCallback' in window) requestIdleCallback(preloadSecondaries, { timeout: 2000 });
      else setTimeout(preloadSecondaries, 1500);

      function switchDotPhoto(dot) {
        const card = dot.closest('.prod-card');
        if (!card) return;
        const img = card.querySelector('.prod-card__photo--main') || card.querySelector('.prod-card__photo');
        if (!img) return;
        const src = dot.dataset.photoSrc;
        if (!src || img.src.endsWith(src.replace(/^\//, ''))) return;
        img.classList.add('is-swapping');
        const pre = new Image();
        pre.onload = () => { img.src = src; requestAnimationFrame(() => img.classList.remove('is-swapping')); };
        pre.onerror = () => img.classList.remove('is-swapping');
        pre.src = src;
        card.querySelectorAll('.prod-card__dot').forEach(d => d.classList.remove('is-active'));
        dot.classList.add('is-active');
      }

      // touchend — для iOS Safari, где e.preventDefault() на click не блокирует навигацию
      grid.addEventListener('touchend', (e) => {
        const dot = e.target.closest('.prod-card__dot');
        if (!dot) return;
        e.preventDefault();
        e.stopPropagation();
        switchDotPhoto(dot);
      }, true);

      grid.addEventListener('click', (e) => {
        const dot = e.target.closest('.prod-card__dot');
        if (!dot) return;
        e.preventDefault();
        e.stopPropagation();
        switchDotPhoto(dot);
      }, true);

      grid.addEventListener('keydown', (e) => {
        if (!e.target.classList.contains('prod-card__dot')) return;
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); e.target.click(); }
      });
    })();

    // Фильтры товаров — с плавным fade-out / fade-in + скрытие пустых групп
    (function() {
      const filtersEl = document.getElementById('catFilters');
      const grid = document.getElementById('catGrid');
      if (!filtersEl || !grid || filtersEl._filtersInited) return;
      filtersEl._filtersInited = true;
      filtersEl.querySelectorAll('.cat-filters__chip').forEach(chip => {
        chip.addEventListener('click', () => {
          window._lastFilterClick = Date.now();
          filtersEl.querySelectorAll('.cat-filters__chip').forEach(c => c.classList.remove('active'));
          chip.classList.add('active');
          const testExpr = chip.dataset.test || 'true';
          const cards = grid.querySelectorAll('.prod-card');
          // Заранее вычисляем видимость, чтобы is-filter-out (pointer-events:none)
          // навешивался ТОЛЬКО на скрываемые карточки — видимые остаются кликабельными
          const visibility = new Map();
          cards.forEach(card => {
            const i = { name: card.dataset.name || '' };
            let show = true;
            try { show = new Function('i', 'return ' + testExpr)(i); } catch (e) { show = true; }
            visibility.set(card, show);
          });
          cards.forEach(card => { if (!visibility.get(card)) card.classList.add('is-filter-out'); });
          setTimeout(() => {
            cards.forEach(card => {
              const show = visibility.get(card);
              card.classList.remove('is-filter-out', 'is-filter-in');
              if (show) {
                card.style.display = '';
                requestAnimationFrame(() => card.classList.add('is-filter-in'));
              } else {
                card.style.display = 'none';
              }
            });
            // Скрыть пустые группы и пересчитать счётчики
            grid.querySelectorAll('.cat-group').forEach(g => {
              const visibleCards = g.querySelectorAll('.prod-card:not([style*="display: none"])');
              const cnt = g.querySelector('.cat-group__count');
              if (cnt) cnt.textContent = visibleCards.length;
              g.style.display = visibleCards.length ? '' : 'none';
            });
            // Layout изменился — пересчитать позиции ScrollTrigger,
            // иначе секции ниже (cat-related, cat-cta) остаются в тумане
            if (window.ScrollTrigger) setTimeout(() => ScrollTrigger.refresh(), 50);
          }, 250);
        });
      });
    })();

    // Сворачивание/разворачивание групп
    document.querySelectorAll('.cat-group__head').forEach(head => {
      if (head._groupHeadInited) return;
      head._groupHeadInited = true;
      head.addEventListener('click', () => {
        const group = head.closest('.cat-group');
        const content = group.querySelector('.cat-group__content');
        const open = head.getAttribute('aria-expanded') !== 'false';
        head.setAttribute('aria-expanded', open ? 'false' : 'true');
        content.dataset.open = open ? 'false' : 'true';
        if (window.ScrollTrigger) setTimeout(() => window.ScrollTrigger.refresh(), 320);
      });
    });

    // "Свернуть все" группы
    (function() {
      const btn = document.getElementById('catToggleAll');
      if (!btn || btn._inited) return;
      btn._inited = true;
      let allOpen = true;
      btn.addEventListener('click', () => {
        allOpen = !allOpen;
        document.querySelectorAll('.cat-group__head').forEach(head => {
          const group = head.closest('.cat-group');
          const content = group.querySelector('.cat-group__content');
          head.setAttribute('aria-expanded', String(allOpen));
          content.dataset.open = String(allOpen);
        });
        const textEl = btn.querySelector('.cat-toggle-all__text');
        if (textEl) textEl.textContent = allOpen ? 'Свернуть все' : 'Развернуть все';
        const icon = btn.querySelector('.cat-toggle-all__icon');
        if (icon) icon.style.transform = allOpen ? '' : 'rotate(-90deg)';
        if (window.ScrollTrigger) setTimeout(() => window.ScrollTrigger.refresh(), 320);
      });
    })();

    // Модалка «Где купить»
    (function() {
      const modal = document.getElementById('buyModal');
      if (!modal || modal._buyModalInited) return;
      modal._buyModalInited = true;

      const overlay = document.getElementById('buyModalOverlay');
      const closeBtn = document.getElementById('buyModalClose');
      const titleEl = document.getElementById('buyModalTitle');
      const articleEl = document.getElementById('buyModalArticle');

      function openBuy(article, name) {
        titleEl.textContent = name || article;
        articleEl.textContent = 'Артикул: ' + article;
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function closeBuy() {
        modal.hidden = true;
        document.body.style.overflow = '';
      }

      document.querySelectorAll('.prod-card__cta[data-buy]').forEach(btn => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const card = btn.closest('.prod-card');
          const name = card?.querySelector('.prod-card__name')?.textContent.trim() || '';
          openBuy(btn.dataset.buy, name);
        });
      });

      if (overlay) overlay.addEventListener('click', closeBuy);
      if (closeBtn) closeBtn.addEventListener('click', closeBuy);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeBuy(); });
    })();
  </script>

  <style is:global>
    /* === CATEGORY PAGE === */
    .cat-hero {
      background: linear-gradient(180deg, var(--warm-100, #f7f4ef) 0%, var(--white, #fff) 100%);
      padding: 120px 0 80px;
    }
    .cat-hero__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; }
    .cat-hero__crumbs {
      display: flex; gap: 12px; align-items: center;
      font-size: 12px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--gray-400, #999); margin-bottom: 48px;
    }
    .cat-hero__crumbs a { color: var(--gray-400, #999); text-decoration: none; transition: color 0.2s; }
    .cat-hero__crumbs a:hover { color: var(--black, #111); }
    .cat-hero__crumbs span { opacity: 0.4; }
    .cat-hero__crumbs-current {
      color: var(--black, #111) !important;
      opacity: 1 !important;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1.5px;
      font-variant-numeric: tabular-nums;
    }

    .cat-hero__grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
      align-items: center;
    }
    .cat-hero__text .label { margin-bottom: 16px; }
    .cat-hero__title {
      font-size: clamp(48px, 6vw, 96px);
      font-weight: 800; line-height: 0.95;
      letter-spacing: -2px; margin-bottom: 24px;
      color: var(--black, #111);
    }
    .cat-hero__subtitle {
      font-size: 18px; font-weight: 500;
      color: var(--gray-600, #666); margin-bottom: 24px;
    }
    .cat-hero__desc {
      font-size: 16px; line-height: 1.7;
      color: var(--gray-600, #666); max-width: 480px;
    }
    .cat-hero__media {
      aspect-ratio: 4/3;
      background: var(--bg-product, #d4d4d2);
      border-radius: 16px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      padding: 40px;
    }
    .cat-hero__media img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      mix-blend-mode: multiply;
    }
    /* Параллакс делается через GSAP в BaseLayout (универсально для Safari) */
    .cat-hero__media-img { will-change: transform; }

    /* Фильтры */
    .cat-products { padding: 60px 0 100px; background: var(--white, #fff); position: relative; z-index: 1; }
    .cat-products__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; }

    .cat-filters {
      margin-bottom: 48px; position: sticky; top: 80px; z-index: 5;
      background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .cat-filters__scroll {
      display: flex; gap: 10px; flex-wrap: wrap;
      padding: 16px 0;
    }
    .cat-filters__chip {
      font-size: 12px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
      padding: 10px 22px; border: 1px solid var(--gray-200, #ddd);
      border-radius: 100px; background: var(--gray-100, #f0eee9); color: var(--gray-600, #666);
      cursor: pointer; transition: all 0.2s ease;
      display: inline-flex; align-items: center; line-height: 1; flex-shrink: 0;
    }
    .cat-filters__chip:hover { border-color: var(--black, #111); color: var(--black, #111); background: var(--white, #fff); }
    .cat-filters__chip.active {
      background: var(--black, #111); color: var(--white, #fff); border-color: var(--black, #111);
    }

    /* Группы (как в сериях) */
    .cat-groups { display: flex; flex-direction: column; gap: 56px; }
    .cat-group {
      scroll-margin-top: 100px;
    }
    .cat-group__head {
      width: 100%; display: flex; align-items: center; gap: 14px;
      padding: 16px 0; margin-bottom: 32px;
      background: none; border: none; border-bottom: 1px solid var(--gray-200, #ddd);
      text-align: left; cursor: pointer;
      transition: border-color 0.2s ease;
    }
    .cat-group__head:hover { border-bottom-color: var(--black, #111); }
    .cat-group__title {
      font-size: clamp(20px, 2vw, 26px);
      font-weight: 700; line-height: 1; letter-spacing: -0.5px;
      color: var(--black, #111); margin: 0;
    }
    .cat-group__count {
      font-size: 13px; font-weight: 500; color: var(--gray-400, #999);
      letter-spacing: 0.5px; min-width: 20px;
    }
    .cat-group__chevron {
      width: 14px; height: 14px; margin-left: auto;
      color: var(--gray-400, #999); transition: transform 0.25s ease, color 0.2s ease;
    }
    .cat-group__head:hover .cat-group__chevron { color: var(--black, #111); }
    .cat-group__head[aria-expanded="false"] .cat-group__chevron { transform: rotate(-90deg); }
    /* Collapsible content через grid-template-rows (как в сериях) */
    .cat-group__content {
      display: grid;
      grid-template-rows: 1fr;
      transition: grid-template-rows 320ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .cat-group__content[data-open="false"] {
      grid-template-rows: 0fr;
    }

    /* Grid карточек */
    .cat-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
    }
    /* Wrapper внутри collapsible — overflow:hidden для grid-rows, padding для теней */
    .cat-group__inner {
      overflow: hidden;
      min-height: 0;
      /* Место под тени hover'а карточек (transform:-6px + shadow 40px) */
      padding: 4px 16px 48px;
      transition: padding 320ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .cat-group__content[data-open="false"] .cat-group__inner {
      padding-top: 0;
      padding-bottom: 0;
    }
    .prod-card {
      background: var(--white, #fff);
      border-radius: 12px; overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease, outline-color 0.3s ease;
      display: flex; flex-direction: column;
      text-decoration: none; color: inherit;
      outline: 1px solid transparent;
      outline-offset: -1px;
      position: relative;
    }
    .prod-card__info { position: relative; }
    .prod-card::after {
      content: '';
      position: absolute; inset: 0;
      border-radius: inherit;
      box-shadow: 0 0 0 0 rgba(140, 184, 107, 0);
      transition: box-shadow 0.4s ease;
      pointer-events: none;
    }
    .prod-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }
    .prod-card:hover::after {
      box-shadow: 0 0 0 2px rgba(140, 184, 107, 0.45), 0 0 24px rgba(140, 184, 107, 0.18);
    }
    .prod-card.is-filter-out {
      opacity: 0;
      transform: scale(0.94);
      transition: opacity 0.25s ease, transform 0.25s ease;
      pointer-events: none;
    }
    .prod-card.is-filter-in {
      animation: filterIn 0.4s ease both;
    }
    @keyframes filterIn {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .prod-card__img {
      aspect-ratio: 1/1; background: var(--bg-product, #d4d4d2);
      display: flex; align-items: center; justify-content: center;
      padding: 36px; overflow: hidden;
      transition: background 0.4s;
      position: relative;
    }
    .prod-card:hover .prod-card__img { background: var(--bg-product, #d4d4d2); }
    .prod-card__img img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      filter: drop-shadow(0 8px 14px rgba(0,0,0,0.12));
      transition:
        transform 0.45s cubic-bezier(.22,1,.36,1),
        filter 0.45s cubic-bezier(.22,1,.36,1);
      position: relative; z-index: 1;
    }
    .prod-card:hover .prod-card__img img {
      transform: translateY(-6px) scale(1.06);
      filter: drop-shadow(0 18px 26px rgba(0,0,0,0.22));
    }
    /* Hover-ракурс: второе фото лежит поверх главного, проявляется при наведении */
    .prod-card__img.has-hover .prod-card__photo {
      position: absolute;
      inset: 36px;
      max-width: calc(100% - 72px); max-height: calc(100% - 72px);
      transition: opacity 0.4s ease, transform 0.45s cubic-bezier(.22,1,.36,1), filter 0.45s cubic-bezier(.22,1,.36,1);
    }
    .prod-card__img.has-hover .prod-card__photo--hover { opacity: 0; }
    .prod-card:hover .prod-card__img.has-hover .prod-card__photo--main { opacity: 0; }
    .prod-card:hover .prod-card__img.has-hover .prod-card__photo--hover { opacity: 1; }

    .prod-card__info {
      padding: 20px 24px 44px;
      display: flex; flex-direction: column;
      flex: 1;
      position: relative;
      overflow: visible;
      min-height: 120px;
    }
    .prod-card__article {
      font-size: 11px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--gray-400, #999); display: block; margin-bottom: 4px;
    }
    .prod-card__name {
      font-size: 16px; font-weight: 700; line-height: 1.35;
      color: var(--black, #111); margin-bottom: 16px;
      flex-grow: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .prod-card__meta-row {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px;
    }
    .prod-card__meta { display: flex; gap: 6px; flex-wrap: wrap; flex: 1; min-width: 0; }
    .prod-card__chip {
      font-size: 10px; font-weight: 500; letter-spacing: 0.5px; text-transform: uppercase;
      padding: 4px 10px; border: 1px solid var(--gray-200, #ddd); border-radius: 100px;
      color: var(--gray-600, #666);
      display: inline-flex; align-items: center; line-height: 1;
      white-space: nowrap; overflow: hidden; flex-shrink: 0;
    }
    /* Точки переключения фото — абсолютно в правом нижнем углу info-секции,
       не зависят от переноса чипов на новую строку */
    .prod-card__dots {
      position: absolute;
      bottom: 16px;
      right: 24px;
      display: flex; gap: 6px;
      align-items: center;
      z-index: 2;
      pointer-events: auto;
    }
    /* Отступ справа в meta-row, чтобы чипы не налезали на точки */
    .prod-card__meta-row { padding-right: 56px; }
    .prod-card__dot {
      width: 14px; height: 14px;
      border-radius: 50%;
      background: rgba(0,0,0,0.18);
      cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease;
      display: inline-block;
    }
    .prod-card__dot:hover { background: rgba(0,0,0,0.4); transform: scale(1.15); }
    .prod-card__dot.is-active {
      background: var(--accent, #8CB86B);
    }
    .prod-card__dots { gap: 8px; } /* override 6px → 8px */
    .prod-card__photo {
      transition: opacity 0.25s ease, transform 0.45s cubic-bezier(.22,1,.36,1), filter 0.45s cubic-bezier(.22,1,.36,1);
    }
    .prod-card__photo.is-swapping { opacity: 0; }
    .prod-card__cta {
      margin: 0 24px 24px; align-self: flex-start;
      font-size: 11px !important; padding: 12px 24px !important;
    }

    .cat-empty {
      text-align: center; padding: 80px 20px;
      font-size: 14px; color: var(--gray-400, #999); letter-spacing: 1px; text-transform: uppercase;
    }

    /* Cross-sell */
    .cat-related { background: var(--warm-100, #f7f4ef); padding: 100px 0; }
    .cat-related__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; }
    .cat-related .label { margin-bottom: 16px; }
    .cat-related__title {
      font-size: clamp(36px, 4vw, 64px);
      font-weight: 800; line-height: 1; letter-spacing: -1.5px;
      margin-bottom: 56px; color: var(--black, #111);
    }
    .cat-related__grid {
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px;
    }
    .cat-related__card {
      text-decoration: none; color: inherit;
      background: var(--white, #fff); border-radius: 12px; overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .cat-related__card:hover { transform: translateY(-6px); box-shadow: 0 16px 32px rgba(0,0,0,0.06); }
    .cat-related__img {
      aspect-ratio: 1/1; background: var(--bg-product, #d4d4d2);
      display: flex; align-items: center; justify-content: center;
      padding: 24px; overflow: hidden;
    }
    .cat-related__img img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      filter: drop-shadow(0 8px 14px rgba(0,0,0,0.12));
      transition:
        transform 0.45s cubic-bezier(.22,1,.36,1),
        filter 0.45s cubic-bezier(.22,1,.36,1);
    }
    .cat-related__card:hover .cat-related__img img {
      transform: translateY(-6px) scale(1.06);
      filter: drop-shadow(0 18px 26px rgba(0,0,0,0.22));
    }
    .cat-related__name {
      padding: 14px 14px 4px;
      font-size: 14px; font-weight: 700; color: var(--black, #111);
    }
    .cat-related__sub {
      padding: 0 14px 14px; display: block;
      font-size: 11px; color: var(--gray-600, #666);
    }

    /* CTA */
    .cat-cta {
      background: var(--dark, #1a1612);
      padding: 120px 0; text-align: center;
    }
    .cat-cta__inner { max-width: 720px; margin: 0 auto; padding: 0 24px; }
    .cat-cta__title {
      font-size: clamp(32px, 4vw, 56px);
      font-weight: 800; line-height: 1.05; letter-spacing: -1px;
      margin-bottom: 16px;
      color: #ffffff !important;
    }
    .cat-cta__sub {
      font-size: 17px; line-height: 1.6;
      color: rgba(255,255,255,0.65) !important;
      margin-bottom: 40px;
    }
    .cat-cta .btn-switch {
      margin: 0 auto;
    }

    /* МОДАЛКА */
    .buy-modal { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
    .buy-modal[hidden] { display: none; }
    .buy-modal__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); }
    .buy-modal__panel {
      position: relative; background: var(--white, #fff); border-radius: 16px;
      padding: 48px; max-width: 480px; width: calc(100% - 40px); max-height: 90vh; overflow: auto;
      box-shadow: 0 24px 80px rgba(0,0,0,0.4); animation: modalIn 0.3s ease;
    }
    @keyframes modalIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .buy-modal__close {
      position: absolute; top: 16px; right: 16px; width: 36px; height: 36px;
      background: transparent; border: none; cursor: pointer; font-size: 28px; color: var(--gray-400, #999);
      transition: color 0.2s;
    }
    .buy-modal__close:hover { color: var(--black, #111); }
    .buy-modal__title { font-size: 24px; font-weight: 700; margin: 12px 0 4px; color: var(--black, #111); }
    .buy-modal__article { font-size: 12px; color: var(--gray-400, #999); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 28px; }
    .buy-modal__links { display: flex; flex-direction: column; gap: 12px; }
    .buy-modal__link {
      display: flex; align-items: center; gap: 16px;
      padding: 18px 20px; border: 1px solid var(--gray-200, #ddd); border-radius: 10px;
      text-decoration: none; color: var(--black, #111);
      transition: all 0.2s ease;
    }
    .buy-modal__link:hover { background: var(--black, #111); color: var(--white, #fff); border-color: var(--black, #111); transform: translateX(4px); }
    .buy-modal__link-logo {
      font-size: 13px; font-weight: 800; letter-spacing: 1px;
      width: 50px; flex-shrink: 0;
    }
    .buy-modal__link-text { flex-grow: 1; font-size: 14px; font-weight: 500; }
    .buy-modal__link-arrow { font-size: 18px; opacity: 0.5; transition: transform 0.2s; }
    .buy-modal__link:hover .buy-modal__link-arrow { transform: translateX(4px); opacity: 1; }

    /* Адаптив */
    @media (max-width: 900px) {
      .cat-hero__inner { padding: 0 24px; }
      .cat-hero__grid { grid-template-columns: 1fr; gap: 40px; }
      .cat-products__inner { padding: 0 24px; }
      .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .cat-related__inner, .cat-cta__inner { padding: 0 24px; }
      .cat-related__grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .cat-related__img { padding: 18px; }
      .cat-related__name { padding: 12px 12px 3px; font-size: 13px; }
      .cat-related__sub { padding: 0 12px 12px; font-size: 10px; }
    }
    /* === Кнопка "Свернуть все" === */
    .cat-controls-bar { display: flex; justify-content: flex-start; margin-bottom: 28px; }
    .cat-toggle-all {
      display: inline-flex; align-items: center; gap: 8px; line-height: 1;
      font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
      padding: 10px 20px; background: none;
      border: 1px solid var(--gray-200, #ddd); border-radius: 100px;
      color: var(--gray-600, #666); cursor: pointer; transition: all 0.2s ease;
    }
    .cat-toggle-all:hover { border-color: var(--black, #111); color: var(--black, #111); }
    .cat-toggle-all__icon { width: 10px; height: 10px; transition: transform 0.25s ease; flex-shrink: 0; }

    @media (max-width: 768px) {
      /* Фильтры: горизонтальный скролл в одну строку */
      /* Sticky фильтр: прозрачный как мобильный хедер */
      .cat-filters {
        background: rgba(255, 255, 255, 0.55); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        border-bottom: 1px solid rgba(0,0,0,0.06);
      }
      /* Скроллируемая строка чипов — overflow на child, sticky на parent */
      .cat-filters__scroll {
        overflow-x: auto; flex-wrap: nowrap; gap: 8px;
        padding: 10px 0 8px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        touch-action: pan-x;
        overscroll-behavior-x: contain;
      }
      .cat-filters__scroll::-webkit-scrollbar { display: none; }
      .cat-filters__chip { font-size: 9px; padding: 6px 11px; letter-spacing: 0.5px; }
      /* Секции: убираем desktop-отступы */
      .cat-hero { padding: 88px 0 44px; }
      .cat-products { padding: 36px 0 60px; }
      .cat-related { padding: 60px 0; }
      /* Контейнеры: 16px */
      .cat-hero__inner, .cat-products__inner, .cat-related__inner { padding: 0 16px; }
      /* Заголовки */
      .cat-hero__title { font-size: clamp(40px, 10vw, 56px); letter-spacing: -1px; }
      /* Карточки товаров: уменьшаем фото-паддинг для читаемости на 2 колонках */
      .prod-card__img { padding: 8px !important; }
      .prod-card__info { flex: 1; height: auto; min-height: 110px; padding: 12px 14px 38px; overflow: visible; }
      .prod-card__name { font-size: 13px; margin-bottom: 8px; }
      .prod-card__dots { bottom: 10px; right: 14px; gap: 10px; }
      .prod-card__dot { width: 18px; height: 18px; }
      .prod-card__meta-row { padding-right: 48px; }
    }
    @media (max-width: 560px) {
      /* Товары: 2 колонки, компактные карточки */
      .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .prod-card__img { padding: 4px !important; }
      .prod-card__info { flex: 1; padding: 8px 10px 36px; min-height: 90px; overflow: visible; }
      .prod-card__article { font-size: 10px; }
      .prod-card__name { font-size: 12px; }
      .prod-card__dots { bottom: 8px; right: 10px; gap: 8px; }
      .prod-card__dot { width: 16px; height: 16px; }
      .prod-card__meta-row { padding-right: 40px; }
      .prod-card__chip { padding: 3px 8px; font-size: 9px; }
      /* Секции */
      .cat-hero { padding: 76px 0 36px; }
      .cat-products { padding: 28px 0 48px; }
      .cat-related { padding: 48px 0; }
      .cat-hero__inner, .cat-products__inner, .cat-related__inner { padding: 0 12px; }
      .cat-related__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .cat-related__img { padding: 14px; }
      .cat-related__name { padding: 10px 10px 3px; font-size: 12px; }
      .cat-related__sub { padding: 0 10px 10px; font-size: 10px; }
    }
    @media (max-width: 480px) {
      .cat-filters { top: 56px; }
    }
  </style>
</BaseLayout>
