---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categoriesMeta from '../../data/categories.json';
import seriesData from '../../data/series.json';
import productsAll from '../../../public/products.json';
import { getProductPhotos } from '../../utils/photos.js';

// Маппинг: ключ в products.json → slug категории на сайте
const keyToCategory = {
  'udl_home': 'extensions-home',
  'udl_garden': 'extensions-garden',
  'power': 'power-connectors',
  'clamps': 'clamps',
  'patch': 'patch-cords',
  'cable': 'cables'
};

export async function getStaticPaths() {
  const all = [];
  const keyToCat = {
    'udl_home': 'extensions-home', 'udl_garden': 'extensions-garden',
    'power': 'power-connectors', 'clamps': 'clamps',
    'patch': 'patch-cords', 'cable': 'cables'
  };
  for (const [key, data] of Object.entries(productsAll)) {
    if (!data.items) continue;
    for (const item of data.items) {
      all.push({ article: item.article, source: 'cat', key, data: item });
    }
  }
  for (const [slug, series] of Object.entries(seriesData)) {
    if (!series.groups) continue;
    for (const groupKey of ['switches', 'sockets', 'frames', 'accessories', 'other']) {
      const items = series.groups[groupKey] || [];
      for (const item of items) {
        all.push({ article: item.article, source: 'series', slug, groupKey, data: item });
      }
    }
  }
  return all.map(p => ({ params: { article: p.article }, props: { meta: p } }));
}

const { article } = Astro.params;
const { meta } = Astro.props;

let product;
if (meta.source === 'cat') {
  const catSlug = keyToCategory[meta.key];
  const photos = getProductPhotos(meta.data.article);
  const fallback = meta.data.photo.replace(/^img\//, '/img/');
  product = {
    article: meta.data.article,
    name: meta.data.name,
    photo: photos[0] || fallback,
    photos: photos.length ? photos : [fallback],
    category: catSlug,
    categoryTitle: categoriesMeta[catSlug]?.title,
    crumbType: 'category'
  };
} else {
  const series = seriesData[meta.slug];
  const photos = getProductPhotos(meta.data.article);
  const fallback = `/img/products/${meta.data.article}.webp`;
  product = {
    article: meta.data.article,
    name: meta.data.name,
    photo: photos[0] || fallback,
    photos: photos.length ? photos : [fallback],
    color: meta.data.color,
    groupKey: meta.groupKey,
    series: meta.slug,
    seriesName: series.name,
    crumbType: 'series'
  };
}

// === Парсинг названия и характеристик ===

function extractMeta(name) {
  const m = [];
  const len = name.match(/(\d+(?:[,.]\d+)?)\s*м(?![м²a-zа-я])/);
  if (len) m.push(`${len[1].replace(',', '.')} м`);
  const sockets = name.match(/(\d+)\s*гн/);
  if (sockets) m.push(`${sockets[1]} ${+sockets[1] === 1 ? 'гнездо' : 'гнёзд'}`);
  if (/с\/з/.test(name)) m.push('с заземлением');
  else if (/б\/з/.test(name)) m.push('без заземления');
  const ip = name.match(/IP\s*(\d{2})/i);
  if (ip) m.push(`IP${ip[1]}`);
  const amp = name.match(/(\d+)\s*А(?![a-z])/);
  if (amp) m.push(`${amp[1]} А`);
  if (/рычажк/i.test(name)) m.push('рычажковая');
  const cat = name.match(/CAT\.?\s*(\d[a-zA-Z]*)/i);
  if (cat) m.push(`Cat.${cat[1]}`);
  if (/FTP/i.test(name)) m.push('FTP');
  else if (/\bUTP\b/i.test(name)) m.push('UTP');
  if (/OUTDOOR/i.test(name)) m.push('Outdoor');
  else if (/INDOOR/i.test(name)) m.push('Indoor');
  return m;
}

// Очищенное короткое название — без артикула, тех-обозначений и кодов.
// Оставляет тип товара и 1-2 ключевых модификатора.
function cleanTitle(name) {
  let t = name
    .replace(/\s*\(AWSPRODUCTS\)/gi, '')
    .replace(/\s*AWSproducts?/gi, '')
    .replace(/"[^"]*"/g, '')
    .replace(/[A-Z]\d+[A-Z]?-\S+/g, '')
    .replace(/\bSoftTouch\b/gi, '')
    .replace(/\bПВС\s*\d+(?:[xх]\d+)?(?:[,.]\d+)?\s*(?:мм²?|mm2)?\b/gi, '')
    .replace(/\b\d+(?:[,.]\d+)?[xх]\d+(?:[,.]\d+)?\s*(?:мм²?|mm2)\b/gi, '')
    .replace(/\b\d+(?:[,.]\d+)?\s*мм²?\b/gi, '')
    .replace(/\bIP\s*\d{2}\b/gi, '')
    .replace(/\bCAT\.?\s*\d[a-zA-Z]*\b/gi, '')
    .replace(/\b(?:FTP|UTP|SAT-?\d+)\b/gi, '')
    .replace(/\b(?:Indoor|Outdoor)\b/gi, '')
    .replace(/[,;]\s*[,;]/g, ',')
    .replace(/^[,.\s]+|[,.\s]+$/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return t;
}

// Сабтайтл — 1-строчная сводка из ключевых характеристик
function buildTeaser(meta) {
  if (!meta.length) return '';
  return meta.slice(0, 3).join(' · ');
}

// 4 highlights в зависимости от типа товара
function buildHighlights(name, seriesName) {
  if (/удлинитель/i.test(name)) {
    return [
      'Кабель ПВС с медными жилами',
      'Корпус из ABS-пластика, устойчивого к нагреву',
      'Защёлкивающиеся гнёзда — стабильный контакт',
      'Гарантия производителя 1 год'
    ];
  }
  if (/клемма/i.test(name)) {
    if (/рычажк/i.test(name)) {
      return [
        'Рычажковый зажим — соединение без инструмента',
        'Подходит для одножильного и многожильного провода',
        'Прозрачный корпус — видно полноту захвата',
        'Сертификация EAC и ГОСТ'
      ];
    }
    return [
      'Полированные латунные контакты',
      'Винтовое соединение под высокий ток',
      'Корпус из самозатухающего полимера',
      'Сертификация EAC и ГОСТ'
    ];
  }
  if (/патч-корд/i.test(name)) {
    return [
      'Литые RJ45 коннекторы с позолоченными контактами',
      'Стабильная передача данных до 1 Гбит/с',
      'Гибкий кабель с защитой от перелома',
      'Совместимость со всем сетевым оборудованием'
    ];
  }
  if (/^кабель/i.test(name)) {
    return [
      'Медные жилы — без алюминия и омеднённой стали',
      'Категория 5e/6 — скорость до 1 Гбит/с',
      'Версии Indoor и Outdoor для разных условий',
      'Соответствие ГОСТ 15845-80'
    ];
  }
  if (/коннектор|разъём|разъем/i.test(name)) {
    return [
      'Класс защиты IP68 — пыль и погружение в воду',
      'Литой корпус из УФ-стойкого пластика',
      'Уплотнительные кольца для герметичности',
      'Подходит для уличного освещения и насосов'
    ];
  }
  if (/выключатель/i.test(name)) {
    return [
      `Серия ${seriesName || 'AWS'} — продуманная классика`,
      'Soft-touch покрытие клавиши',
      'Латунные контакты, тихий ход',
      'Гарантия производителя 2 года'
    ];
  }
  if (/розетк/i.test(name)) {
    return [
      'Защитные шторки от детей',
      'Полированная латунь на контактах',
      'Корпус из ABS, не желтеет со временем',
      'Гарантия производителя 2 года'
    ];
  }
  if (/рамк/i.test(name)) {
    return [
      'Точная геометрия и ровные линии',
      'ABS-пластик устойчивый к УФ',
      'Совместимость с механизмами серии',
      'Гарантия производителя 2 года'
    ];
  }
  return [
    'Качественные материалы и сборка',
    'Стандарт EAC и ГОСТ',
    'Гарантия производителя',
    'Совместимость с распространёнными подрозетниками'
  ];
}

// Таблица характеристик
function buildSpecs(p) {
  const rows = [['Артикул', p.article]];
  const n = p.name;

  const len = n.match(/(\d+(?:[,.]\d+)?)\s*м(?![м²a-zа-я])/);
  if (len) rows.push(['Длина', `${len[1].replace(',', '.')} м`]);

  const sockets = n.match(/(\d+)\s*гн/);
  if (sockets) rows.push(['Гнёзд', sockets[1]]);

  if (/с\/з/.test(n)) rows.push(['Заземление', 'Да']);
  else if (/б\/з/.test(n)) rows.push(['Заземление', 'Нет']);

  const wire = n.match(/(\d+(?:[,.]\d+)?)[xх](\d+(?:[,.]\d+)?)\s*(?:мм²?|mm2)?/);
  if (wire) rows.push(['Сечение жилы', `${wire[1]}×${wire[2]} мм²`]);

  if (/\bПВС\b/i.test(n)) rows.push(['Тип кабеля', 'ПВС']);
  if (/\bВВГ/i.test(n)) rows.push(['Тип кабеля', 'ВВГ']);

  const ip = n.match(/IP\s*(\d{2})/i);
  if (ip) rows.push(['Класс защиты', `IP${ip[1]}`]);

  const amp = n.match(/(\d+)\s*А(?![a-z])/);
  if (amp) rows.push(['Номинальный ток', `${amp[1]} А`]);

  const cat = n.match(/CAT\.?\s*(\d[a-zA-Z]*)/i);
  if (cat) rows.push(['Категория', `Cat.${cat[1]}`]);

  if (/FTP/i.test(n)) rows.push(['Экран', 'FTP (фольгированный)']);
  else if (/\bUTP\b/i.test(n)) rows.push(['Экран', 'UTP (без экрана)']);

  if (/OUTDOOR/i.test(n)) rows.push(['Применение', 'Outdoor — для улицы']);
  else if (/INDOOR/i.test(n)) rows.push(['Применение', 'Indoor — для помещений']);

  if (p.color) {
    const colorRu = { white: 'Белый', black: 'Чёрный' }[p.color] || p.color;
    rows.push(['Цвет', colorRu]);
  }

  if (p.seriesName) rows.push(['Серия', p.seriesName]);

  if (/удлинитель|клемма|патч-корд|^кабель|коннектор|разъ[её]м/i.test(n)) {
    rows.push(['Гарантия', '1 год']);
  } else {
    rows.push(['Гарантия', '2 года']);
  }

  rows.push(['Сертификация', 'EAC, ГОСТ']);
  rows.push(['Бренд', 'AWS Products']);

  return rows;
}

const meta3 = extractMeta(product.name);
const title = cleanTitle(product.name);
const teaser = buildTeaser(meta3);
const highlights = buildHighlights(product.name, product.seriesName);
const specs = buildSpecs(product);

// Связанные товары
function findRelated() {
  const list = [];
  if (product.crumbType === 'category') {
    const key = Object.keys(keyToCategory).find(k => keyToCategory[k] === product.category);
    const data = productsAll[key];
    if (data?.items) {
      list.push(...data.items.filter(i => i.article !== product.article).slice(0, 4).map(i => {
        const ph = getProductPhotos(i.article);
        return {
          article: i.article,
          name: cleanTitle(i.name),
          photo: ph[0] || i.photo.replace(/^img\//, '/img/'),
          hover: ph[1] || null,
          allPhotos: ph.length > 2 ? ph : null,
          meta: extractMeta(i.name).slice(0, 2)
        };
      }));
    }
  } else {
    const series = seriesData[product.series];
    if (series?.groups?.[product.groupKey]) {
      list.push(...series.groups[product.groupKey]
        .filter(i => i.article !== product.article)
        .slice(0, 4)
        .map(i => {
          const ph = getProductPhotos(i.article);
          return {
            article: i.article,
            name: i.name,
            photo: ph[0] || `/img/products/${i.article}.webp`,
            hover: ph[1] || null,
            allPhotos: ph.length > 2 ? ph : null,
            meta: extractMeta(i.name).slice(0, 2)
          };
        }));
    }
  }
  return list;
}

const related = findRelated();

// Описание
function buildDescription() {
  if (/удлинитель/i.test(product.name)) {
    return 'Удлинитель собран на качественном кабеле ПВС с медными жилами — стабильное соединение и низкий нагрев под нагрузкой. Корпус выполнен из ABS-пластика, устойчивого к ультрафиолету и температурным перепадам. Защёлкивающиеся гнёзда удерживают вилку без люфта, обеспечивая надёжный контакт. Подходит для использования в быту, на даче и на улице — модели с маркировкой Outdoor имеют усиленную изоляцию для уличных условий.';
  }
  if (/клемма/i.test(product.name)) {
    if (/рычажк/i.test(product.name)) {
      return 'Рычажковая клемма — самый быстрый способ соединить провода без пайки и инструмента. Поднимаете рычаг, вставляете зачищенный провод, опускаете рычаг — соединение готово. Прозрачный корпус позволяет визуально контролировать качество захвата. Подходит для одножильного и многожильного медного провода.';
    }
    return 'Винтовая клемма с латунными контактами для надёжного соединения проводов в распределительных коробках, светильниках и бытовой электрике. Полированные контактные группы обеспечивают стабильное соединение без подгорания. Корпус из самозатухающего полимера соответствует требованиям пожарной безопасности.';
  }
  if (/патч-корд/i.test(product.name)) {
    return 'Патч-корд для коммутации сетевого оборудования — серверов, роутеров, коммутаторов, рабочих мест. Литые RJ45 коннекторы с позолоченными контактами обеспечивают стабильную передачу данных без потерь. Гибкий медный кабель сохраняет работоспособность после многократных перегибов и совместим со всем стандартным сетевым оборудованием.';
  }
  if (/^кабель/i.test(product.name)) {
    return 'Сетевой кабель с медными жилами категории Cat.5e или Cat.6 — стандарт для построения локальных сетей со скоростью до 1 Гбит/с. Без алюминиевых заменителей и омеднённой стали — только чистая медь, что гарантирует стабильную передачу сигнала на расстоянии до 100 м. Версии Indoor и Outdoor отличаются изоляцией для соответствующих условий прокладки.';
  }
  if (/коннектор|разъ[её]м/i.test(product.name)) {
    return 'Кабельный коннектор с классом защиты IP68 — выдерживает погружение в воду и пыль высокой концентрации. Литой корпус из УФ-стойкого пластика, уплотнительные кольца обеспечивают герметичность соединения. Используется для уличного освещения, садовых насосов, систем полива и других уличных электросистем где требуется стойкость к атмосферным условиям.';
  }
  if (/выключатель/i.test(product.name)) {
    const s = product.seriesName || 'AWS';
    return `Выключатель серии ${s} — продуманная классика для жилых интерьеров. Soft-touch покрытие клавиши приятно на ощупь и не собирает отпечатков. Латунные контактные группы и тихий ход механизма обеспечивают стабильную работу на годы вперёд. Совместим со стандартными подрозетниками 68 мм, монтаж винтовыми зажимами с чёткой маркировкой.`;
  }
  if (/розетк/i.test(product.name)) {
    return 'Розетка с защитными шторками от детей — отверстия закрыты, пока в них одновременно не вставлена вилка. Контактные группы из полированной латуни, корпус из прочного ABS-пластика, не желтеет под воздействием УФ. Точная посадка в подрозетники 68 мм без зазоров.';
  }
  if (/рамк/i.test(product.name)) {
    return 'Рамка для монтажа выключателей и розеток одной серии. Точная геометрия, ровные линии и выверенные пропорции. ABS-пластик устойчив к ультрафиолету и сохраняет цвет годами. Совместима только с механизмами своей серии — не подходит к Werkel, Schneider или Legrand.';
  }
  return 'Изделие бренда AWS Products. Качественные материалы, надёжная сборка и контроль на производстве. Совместимо со стандартными подрозетниками 68 мм. Сертифицировано EAC и ГОСТ.';
}

const description = buildDescription();

// Маркетплейсы — стиль как у блока "Где купить" на главной
const marketplaceLinks = [
  {
    key: 'ozon',
    label: 'Маркетплейс',
    name: 'Ozon',
    url: 'https://www.ozon.ru/seller/ip-popov-a-yu/',
    logo: '/aws-brand-site/logo/retailers/ozon.png'
  },
  {
    key: 'wb',
    label: 'Маркетплейс',
    name: 'Wildberries',
    url: 'https://www.wildberries.ru/brands/312201750-awsproducts',
    logo: '/aws-brand-site/logo/retailers/wildberries.png'
  },
  {
    key: 'ec',
    label: 'Партнёр · опт',
    name: 'Электроцентр',
    url: 'https://stv39.ru/help/nashi-partnery/awsproducts/',
    logo: '/aws-brand-site/logo/retailers/electrocentre.png'
  }
];

---
<BaseLayout title={`${title || product.article} — AWS Products`} description={description.slice(0, 160)}>

  <!-- HERO ТОВАРА -->
  <section class="prod-hero">
    <div class="prod-hero__inner">
      <nav class="prod-hero__crumbs">
        <a href="/aws-brand-site/">Главная</a>
        <span>/</span>
        {product.crumbType === 'category' ? (
          <>
            <a href="/aws-brand-site/#categories">Ассортимент</a>
            <span>/</span>
            <a href={`/aws-brand-site/category/${product.category}`}>{product.categoryTitle}</a>
          </>
        ) : (
          <>
            <a href="/aws-brand-site/#series">Коллекции</a>
            <span>/</span>
            <a href={`/aws-brand-site/series/${product.series}`}>Серия {product.seriesName}</a>
          </>
        )}
        <span>/</span>
        <span class="prod-hero__crumbs-current">{product.article}</span>
      </nav>

      <div class="prod-hero__grid">
        <div class="prod-hero__media-wrap">
          <div class="prod-hero__media" data-reveal="zoom">
            {product.photos.map((src, i) => (
              <img src={src} alt={title} class={`prod-hero__photo${i === 0 ? ' is-active' : ''}`} data-photo-index={i} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" onerror="this.dataset.broken='1';this.style.display='none';this.parentElement.classList.add('has-broken');" />
            ))}
            <div class="prod-hero__placeholder">Фото готовится</div>
          </div>
          {product.photos.length > 1 && (
            <div class="prod-hero__thumbs" role="tablist" aria-label="Дополнительные фото">
              {product.photos.map((src, i) => (
                <button type="button" class={`prod-hero__thumb${i === 0 ? ' is-active' : ''}`} data-thumb-index={i} aria-label={`Фото ${i + 1}`} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
                  <img src={src} alt="" loading="lazy" decoding="async" />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="prod-hero__text">
          <button class="prod-hero__article" type="button" data-reveal="blur" style="--i: 0" title="Скопировать артикул">
            <span class="prod-hero__article-text">{product.article}</span>
            <svg class="prod-hero__article-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
          </button>
          <h1 class="prod-hero__title" data-reveal="focus" style="--i: 1">{title}</h1>

          {meta3.length > 0 && (
            <div class="prod-hero__chips" data-reveal="slide" style="--i: 3">
              {meta3.map(m => <span class="prod-hero__chip">{m}</span>)}
            </div>
          )}

          <ul class="prod-hero__highlights">
            {highlights.map((h, i) => (
              <li class="prod-highlight" data-reveal="slide" style={`--i: ${4 + i}`}>
                <span class="prod-highlight__check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12 L10 17 L19 7"/>
                  </svg>
                </span>
                <span class="prod-highlight__text">{h}</span>
              </li>
            ))}
          </ul>

          <div class="prod-hero__buy">
            <span class="prod-hero__buy-label">Где купить</span>
            <div class="prod-buy-row">
              {marketplaceLinks.map((m, i) => (
                <a href={m.url} target="_blank" rel="noopener"
                   class={`prod-buy-btn prod-buy-btn--${m.key}`}
                   data-reveal="slide" style={`--i: ${8 + i}`}>
                  <div class="prod-buy-btn__watermark" aria-hidden="true">
