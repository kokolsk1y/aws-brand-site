---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProductPhotos } from '../../utils/photos.js';
import seriesData from '../../data/series.json';

export async function getStaticPaths() {
  return Object.keys(seriesData).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const series = seriesData[slug];
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

const otherSeries = Object.values(seriesData).filter(s => s.slug !== slug);
const defaultColor = series.colors[0];

function getCardPhotoStyle(article) {
  // Рамки — всегда 1:1 (аксиома: карточки одного размера независимо от числа постов)
  // Уменьшаем только padding чтобы многопостные рамки не выглядели крошечными
  const m = article.match(/-0(28|29|30|31|32)\b/);
  if (!m) return '';
  const n = parseInt(m[1]);
  const pad = { 28: '28px', 29: '20px', 30: '14px', 31: '14px', 32: '10px' }[n];
  return `--photo-pad: ${pad}`;
}
---
<BaseLayout title={`${series.name} — серия AWS Products`} description={series.description}>

  <!-- HERO СЕРИИ -->
  <section class="ser-hero">
    <div class="ser-hero__inner">
      <nav class="ser-hero__crumbs">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/#series">Коллекции</a>
        <span>/</span>
        <span class="ser-hero__crumbs-current">{series.name}</span>
      </nav>

      <div class="ser-hero__grid">
        <div class="ser-hero__text">
          {series.badge && <span class="ser-hero__badge" data-reveal="blur">{series.badge}</span>}
          <h1 class="ser-hero__title" data-reveal="focus" style={`view-transition-name: series-${slug}-title`}>{series.name}</h1>
          <p class="ser-hero__tagline" data-reveal="blur">{series.tagline}</p>
          <p class="ser-hero__desc" data-reveal="blur">{series.description}</p>

          {series.colors.length > 0 && (
            <div class="ser-hero__colors" id="serColors" data-reveal="slide">
              {series.colors.map((c, i) => (
                <button
                  class={`ser-hero__color-btn ${i === 0 ? 'active' : ''}`}
                  data-img={`${BASE}${c.img}`}
                  data-color={c.key}
                >
                  <span class={`dot dot--${c.key}`}></span>
                  {c.label}
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="ser-hero__media" data-reveal="zoom">
          {defaultColor ? (
            <img id="serHeroImg" src={`${BASE}${defaultColor.img}`} alt={series.name} style={`view-transition-name: series-${slug}-image`} />
          ) : (
            <div class="ser-hero__placeholder">Скоро</div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- LINEUP — все 3 группы -->
  {series.groups && (series.groups.switches.length + series.groups.sockets.length + series.groups.frames.length) > 0 && (
    <section class="ser-lineup">
      <div class="ser-lineup__inner">
        <h2 class="ser-lineup__title" data-reveal="focus">Что входит в серию</h2>
        <p class="ser-lineup__subtitle" data-reveal="blur">
          <a href="#ser-group-switches" class="ser-lineup__count-link" data-jump="ser-group-switches">{series.groups.switches.length} выключателей</a>
          <span class="ser-lineup__dot">·</span>
          <a href="#ser-group-sockets" class="ser-lineup__count-link" data-jump="ser-group-sockets">{series.groups.sockets.length} розеток</a>
          <span class="ser-lineup__dot">·</span>
          <a href="#ser-group-frames" class="ser-lineup__count-link" data-jump="ser-group-frames">{series.groups.frames.length} рамок</a>
        </p>

        <div class="ser-lineup__controls">
          <div class="ser-lineup__filter" id="serColorFilter">
            <button class="ser-lineup__chip active" data-color="all">Все ({series.groups.switches.length + series.groups.sockets.length + series.groups.frames.length})</button>
            <button class="ser-lineup__chip" data-color="white">Белые</button>
            <button class="ser-lineup__chip" data-color="black">Чёрные</button>
          </div>
        </div>
        <button class="ser-lineup__toggle-all" id="serToggleAll" type="button" aria-label="Свернуть все группы">
          <span class="ser-lineup__toggle-all-text">Свернуть все</span>
          <svg viewBox="0 0 12 12" class="ser-lineup__toggle-all-icon" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        {[
          { key: 'switches', title: 'Выключатели', items: series.groups.switches },
          { key: 'sockets',  title: 'Розетки',     items: series.groups.sockets  },
          { key: 'frames',   title: 'Рамки',       items: series.groups.frames   }
        ].filter(g => g.items.length > 0).map(group => (
          <div class="ser-lineup__group" data-group={group.key} id={`ser-group-${group.key}`}>
            <button class="ser-lineup__group-head" type="button"
                    aria-expanded="true"
                    aria-controls={`ser-group-content-${group.key}`}
                    id={`ser-group-trigger-${group.key}`}>
              <h3 class="ser-lineup__group-title">{group.title}</h3>
              <span class="ser-lineup__group-count">{group.items.length}</span>
              <svg viewBox="0 0 14 14" class="ser-lineup__group-chevron" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="ser-lineup__group-content"
                 id={`ser-group-content-${group.key}`}
                 role="region"
                 aria-labelledby={`ser-group-trigger-${group.key}`}
                 data-open="true">
              <div class="ser-lineup__group-inner">
                <div class="ser-lineup__grid" data-reveal-grid>
                  {group.items.map((item, idx) => {
                    const photos = getProductPhotos(item.article);
                    const main = photos[0] || `/img/products/${item.article}.webp`;
                    const showDots = photos.length >= 2;
                    return (
                    <a href={`/product/${item.article}`} class="ser-lineup__card" data-color={item.color || 'unknown'} data-tilt data-tilt-max="5" data-reveal="slide" style={`--i: ${idx % 9}`}>
                      <div class="ser-lineup__photo" style={getCardPhotoStyle(item.article)}>
                        <img src={main} alt={item.name} class="ser-lineup__img ser-lineup__img--main" loading="lazy" onerror="this.style.display='none';this.parentElement.querySelector('.ser-lineup__photo-fallback').style.display='flex'" />
                        <div class="ser-lineup__photo-fallback" style="display:none">
                          <span class={`dot dot--${item.color || 'white'}`}></span>
                        </div>
                      </div>
                      <div class="ser-lineup__body">
                        <span class="ser-lineup__article">{item.article}</span>
                        <h4 class="ser-lineup__name">{item.name}</h4>
                        {showDots && (
                          <div class="ser-lineup__dots" aria-label="Переключить фото">
                            {photos.map((src, i) => (
                              <span class={`prod-card__dot${i === 0 ? ' is-active' : ''}`} role="button" tabindex="0" data-photo-idx={i} data-photo-src={src} aria-label={`Фото ${i + 1}`}></span>
                            ))}
                          </div>
                        )}
                      </div>
                    </a>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        ))}

        <div class="ser-lineup__cta">
          <a href="#" class="btn-switch" id="serBuyBtn">Где купить серию</a>
        </div>
      </div>
    </section>
  )}

  <!-- CROSS-SELL: другие серии -->
  <section class="ser-related">
    <div class="ser-related__inner">
      <h2 class="ser-related__title" data-reveal="focus">Посмотреть<br>остальные коллекции</h2>
      <div class="ser-related__grid" data-reveal-grid>
        {otherSeries.map((s, idx) => (
          <a href={`/series/${s.slug}`} class="ser-related__card" data-astro-reload data-tilt data-tilt-max="5" data-reveal="slide" style={`--i: ${idx}`}>
            <div class="ser-related__img">
              {s.colors[0] ? <img src={s.colors[0].img} alt={s.name} /> : <span class="ser-related__placeholder">Скоро</span>}
            </div>
            <h3 class="ser-related__name">{s.name}</h3>
            <span class="ser-related__sub">{s.tagline}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cat-cta">
    <div class="cat-cta__inner">
      <h2 class="cat-cta__title" data-reveal="focus">Не нашли подходящий?</h2>
      <p class="cat-cta__sub" data-reveal="blur">Напишите нам — расскажем подробнее или подберём аналог</p>
      <a href="mailto:info@awsproducts.ru" class="btn-switch" data-reveal="slide">Связаться</a>
    </div>
  </section>

  <!-- МОДАЛКА «Где купить» -->
  <div class="buy-modal" id="buyModal" role="dialog" aria-modal="true" aria-label="Где купить" hidden>
    <div class="buy-modal__overlay" id="buyModalOverlay"></div>
    <div class="buy-modal__panel">
      <button class="buy-modal__close" id="buyModalClose" aria-label="Закрыть">&times;</button>
      <p class="label">Где купить</p>
      <h3 class="buy-modal__title">Серия {series.name}</h3>
      <p class="buy-modal__article">Все артикулы доступны на маркетплейсах</p>
      <div class="buy-modal__links">
        <a href="https://www.ozon.ru/seller/ip-popov-a-yu/" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">OZON</span>
          <span class="buy-modal__link-text">Маркетплейс Ozon</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
        <a href="https://www.wildberries.ru/brands/312201750-awsproducts" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">WB</span>
          <span class="buy-modal__link-text">Wildberries</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
        <a href="https://stv39.ru/help/nashi-partnery/awsproducts/" target="_blank" rel="noopener" class="buy-modal__link">
          <span class="buy-modal__link-logo">ЭЦ</span>
          <span class="buy-modal__link-text">Электроцентр</span>
          <span class="buy-modal__link-arrow">→</span>
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Точки переключения фото на карточках товаров серии
    (function () {
      const lineup = document.querySelector('.ser-lineup');
      if (!lineup || lineup.dataset.dotsInit === '1') return;
      lineup.dataset.dotsInit = '1';

      function preloadSecondaries() {
        lineup.querySelectorAll('.prod-card__dot[data-photo-idx="1"]').forEach(d => {
          const src = d.dataset.photoSrc;
          if (src) { const im = new Image(); im.decoding = 'async'; im.src = src; }
        });
      }
      if ('requestIdleCallback' in window) requestIdleCallback(preloadSecondaries, { timeout: 2000 });
      else setTimeout(preloadSecondaries, 1500);

      function switchLineupDotPhoto(dot) {
        const card = dot.closest('.ser-lineup__card');
        if (!card) return;
        const img = card.querySelector('.ser-lineup__img--main') || card.querySelector('.ser-lineup__img');
        if (!img) return;
        const src = dot.dataset.photoSrc;
        if (!src || img.src.endsWith(src.replace(/^\//, ''))) return;
        img.classList.add('is-swapping');
        const pre = new Image();
        pre.onload = () => { img.src = src; requestAnimationFrame(() => img.classList.remove('is-swapping')); };
        pre.onerror = () => img.classList.remove('is-swapping');
        pre.src = src;
        card.querySelectorAll('.prod-card__dot').forEach(d => d.classList.remove('is-active'));
        dot.classList.add('is-active');
      }

      // touchend — для iOS Safari
      lineup.addEventListener('touchend', (e) => {
        const dot = e.target.closest('.prod-card__dot');
        if (!dot) return;
        e.preventDefault();
        e.stopPropagation();
        switchLineupDotPhoto(dot);
      }, true);

      lineup.addEventListener('click', (e) => {
        const dot = e.target.closest('.prod-card__dot');
        if (!dot) return;
        e.preventDefault();
        e.stopPropagation();
        switchLineupDotPhoto(dot);
      }, true);

      lineup.addEventListener('keydown', (e) => {
        if (!e.target.classList.contains('prod-card__dot')) return;
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); e.target.click(); }
      });
    })();

    // Переключение цвета в hero
    (function() {
      const colors = document.getElementById('serColors');
      const heroImg = document.getElementById('serHeroImg');
      if (!colors || !heroImg || colors._colorBtnsInited) return;
      colors._colorBtnsInited = true;
      colors.querySelectorAll('.ser-hero__color-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          colors.querySelectorAll('.ser-hero__color-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          heroImg.style.opacity = '0';
          setTimeout(() => { heroImg.src = btn.dataset.img; heroImg.style.opacity = '1'; }, 200);
        });
      });
    })();

    // Модалка «Где купить»
    (function() {
      const modal = document.getElementById('buyModal');
      if (!modal || modal._buyModalInited) return;
      modal._buyModalInited = true;
      const overlay = document.getElementById('buyModalOverlay');
      const closeBtn = document.getElementById('buyModalClose');
      const buyBtn = document.getElementById('serBuyBtn');
      function openBuy() { modal.hidden = false; document.body.style.overflow = 'hidden'; }
      function closeBuy() { modal.hidden = true; document.body.style.overflow = ''; }
      if (buyBtn) buyBtn.addEventListener('click', e => { e.preventDefault(); openBuy(); });
      if (overlay) overlay.addEventListener('click', closeBuy);
      if (closeBtn) closeBtn.addEventListener('click', closeBuy);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeBuy(); });
    })();

    // Collapsible групп
    function setGroupState(trigger, open) {
      const panelId = trigger.getAttribute('aria-controls');
      const panel = document.getElementById(panelId);
      if (!panel) return;
      trigger.setAttribute('aria-expanded', String(open));
      panel.dataset.open = String(open);
      if (window.ScrollTrigger) setTimeout(() => window.ScrollTrigger.refresh(), 320);
    }
    function toggleGroup(trigger) {
      setGroupState(trigger, trigger.getAttribute('aria-expanded') !== 'true');
    }

    document.querySelectorAll('.ser-lineup__group-head').forEach(head => {
      if (head._groupHeadInited) return;
      head._groupHeadInited = true;
      head.addEventListener('click', () => toggleGroup(head));
    });

    // Фильтр lineup по цвету
    (function() {
      const filter = document.getElementById('serColorFilter');
      if (!filter || filter._colorFilterInited) return;
      filter._colorFilterInited = true;
      filter.querySelectorAll('.ser-lineup__chip').forEach(chip => {
        chip.addEventListener('click', () => {
          filter.querySelectorAll('.ser-lineup__chip').forEach(c => c.classList.remove('active'));
          chip.classList.add('active');
          const color = chip.dataset.color;
          document.querySelectorAll('.ser-lineup__card').forEach(card => {
            const c = card.dataset.color;
            const show = color === 'all' || c === color || c === 'unknown';
            card.style.display = show ? '' : 'none';
            if (show) card.style.setProperty('--reveal-progress', '1');
          });
          if (window.ScrollTrigger) ScrollTrigger.refresh();
          document.querySelectorAll('.ser-lineup__group').forEach(g => {
            const visible = g.querySelectorAll('.ser-lineup__card:not([style*="none"])').length;
            g.style.display = visible > 0 ? '' : 'none';
            if (visible > 0) {
              const trigger = g.querySelector('.ser-lineup__group-head');
              if (trigger && trigger.getAttribute('aria-expanded') === 'false') setGroupState(trigger, true);
            }
          });
        });
      });
    })();

    // Toggle all
    (function() {
      const toggleAllBtn = document.getElementById('serToggleAll');
      if (!toggleAllBtn || toggleAllBtn._toggleAllInited) return;
      toggleAllBtn._toggleAllInited = true;
      toggleAllBtn.addEventListener('click', () => {
        const heads = Array.from(document.querySelectorAll('.ser-lineup__group-head'));
        const anyOpen = heads.some(h => h.getAttribute('aria-expanded') === 'true');
        const targetState = !anyOpen;
        heads.forEach(h => setGroupState(h, targetState));
        toggleAllBtn.dataset.state = targetState ? 'expanded' : 'collapsed';
        toggleAllBtn.querySelector('.ser-lineup__toggle-all-text').textContent = targetState ? 'Свернуть все' : 'Развернуть все';
        toggleAllBtn.setAttribute('aria-label', targetState ? 'Свернуть все группы' : 'Развернуть все группы');
      });
    })();

    // Click на счётчик "15 выключателей" → раскрыть группу + скролл
    document.querySelectorAll('.ser-lineup__count-link[data-jump]').forEach(link => {
      if (link._countLinkInited) return;
      link._countLinkInited = true;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const groupId = link.dataset.jump;
        const group = document.getElementById(groupId);
        if (!group) return;
        const trigger = group.querySelector('.ser-lineup__group-head');
        const isOpen = trigger?.getAttribute('aria-expanded') === 'true';
        const doScroll = () => {
          const rect = group.getBoundingClientRect();
          window.scrollTo({ top: rect.top + window.pageYOffset - 100, behavior: 'smooth' });
        };
        if (!isOpen && trigger) {
          setGroupState(trigger, true);
          const panel = group.querySelector('.ser-lineup__group-content');
          const onEnd = (ev) => {
            if (ev.propertyName !== 'grid-template-rows') return;
            panel.removeEventListener('transitionend', onEnd);
            doScroll();
          };
          panel.addEventListener('transitionend', onEnd);
          setTimeout(doScroll, 400);
        } else {
          doScroll();
        }
      });
    });
  </script>

  <script>
    // При back/forward навигации (юзер нажал «Назад») отменяем view transition
    // целиком — морфинг заголовка/картинки в обратную сторону выглядит коряво
    // из-за разных шрифтовых пропорций между страницей серии и карточкой главной.
    window.addEventListener('pageswap', (e) => {
      if (!e.viewTransition) return;
      const navType = e.activation?.navigationType;
      if (navType === 'traverse') {
        e.viewTransition.skipTransition();
      }
    });
  </script>

  <style is:global>
    /* === SERIES PAGE === */
    .ser-hero {
      background: linear-gradient(180deg, var(--warm-100, #f7f4ef) 0%, var(--white, #fff) 100%);
      padding: 120px 0 80px;
    }
    .ser-hero__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; }
    .ser-hero__crumbs {
      display: flex; gap: 12px; align-items: center;
      font-size: 12px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--gray-400, #999); margin-bottom: 48px;
    }
    .ser-hero__crumbs a { color: var(--gray-400, #999); text-decoration: none; transition: color 0.2s; }
    .ser-hero__crumbs a:hover { color: var(--black, #111); }
    .ser-hero__crumbs span { opacity: 0.4; }
    .ser-hero__crumbs-current {
      color: var(--black, #111) !important;
      opacity: 1 !important;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1.5px;
      font-variant-numeric: tabular-nums;
    }

    .ser-hero__grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .ser-hero__text .label { margin-bottom: 16px; }
    .ser-hero__badge {
      display: inline-block;
      font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      background: var(--accent, #8CB86B); color: var(--white, #fff);
      padding: 5px 14px; border-radius: 100px; margin-bottom: 16px;
    }
    .ser-hero__title {
      font-size: clamp(56px, 7vw, 112px);
      font-weight: 800; line-height: 1; letter-spacing: -2px;
      margin-bottom: 20px; color: var(--black, #111);
      text-wrap: balance;
    }
    .ser-hero__tagline {
      font-size: 20px; font-weight: 500; color: var(--gray-600, #666);
      margin-bottom: 24px;
    }
    .ser-hero__desc {
      font-size: 16px; line-height: 1.7; color: var(--gray-600, #666);
      max-width: 480px; margin-bottom: 36px;
    }
    .ser-hero__colors {
      display: flex; gap: 12px;
    }
    .ser-hero__color-btn {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 12px 22px; border: 1px solid var(--gray-200, #ddd);
      border-radius: 100px; background: transparent;
      font-size: 12px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--gray-600, #666); cursor: pointer;
      transition: all 0.2s ease;
    }
    .ser-hero__color-btn:hover { border-color: var(--black, #111); color: var(--black, #111); }
    .ser-hero__color-btn.active {
      background: var(--black, #111); color: var(--white, #fff); border-color: var(--black, #111);
    }
    .ser-hero__color-btn .dot { width: 16px; height: 16px; border-radius: 50%; pointer-events: none; }

    .ser-hero__media {
      aspect-ratio: 4/3; background: var(--bg-product, #d4d4d2);
      border-radius: 16px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      padding: 60px;
    }
    .ser-hero__media img {
      max-width: 100%; max-height: 100%; object-fit: contain;
      transition: opacity 0.3s ease;
    }
    .ser-hero__placeholder {
      font-size: 14px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase;
      color: rgba(0,0,0,0.2); border: 1.5px dashed rgba(0,0,0,0.15);
      padding: 28px 40px; border-radius: 6px;
    }

    /* Особенности — горизонтально 4 колонки с крупным outlined номером */
    .ser-features { background: var(--white, #fff); padding: 100px 0; }
    .ser-features__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; }
    .ser-features .label { margin-bottom: 16px; }
    .ser-features__title {
      font-size: clamp(36px, 4vw, 64px);
      font-weight: 800; line-height: 1; letter-spacing: -1.5px;
      margin-bottom: 56px; color: var(--black, #111);
    }
    .ser-features__list {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    }
    .ser-feature {
      position: relative;
      padding: 40px 28px 32px;
      border-radius: 12px;
      background: var(--white, #fff);
      border: 1px solid var(--gray-100, #f0eee9);
      overflow: hidden;
      min-height: 260px;
      display: flex; flex-direction: column; justify-content: flex-end;
      opacity: 0;
      transform: translateY(40px);
      transition:
        opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
